# Supabase Transaction Pooler connection URL; application runtime uses this.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[POOLER_HOST]:6543/postgres?pgbouncer=true&sslmode=require"
# Supabase direct connection URL; only `prisma migrate deploy` uses this.
DIRECT_URL="postgresql://postgres:[PASSWORD]@[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"
# Server-only StableOps sandbox API key. Never expose it with a NEXT_PUBLIC_ prefix.
STABLEOPS_API_KEY="sk_sandbox_..."
# Server-only signing secret created with the StableOps webhook endpoint.
STABLEOPS_WEBHOOK_SECRET="whsec_..."
# The final production origin, without a path (for example https://your-app.vercel.app).
APP_URL="https://your-app.example"
